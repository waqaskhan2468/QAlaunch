# ─── App URL (required on Vercel for Inngest + report links) ─────────────────
# Use your production domain, e.g. https://getqalaunch.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional buckets (defaults shown)
# SUPABASE_SCREENSHOT_BUCKET=scan-screenshots
# SUPABASE_REPORT_BUCKET=

# ─── Inngest (required on Vercel — without these scans stay on "Queued") ─────
# Create keys at https://app.inngest.com → your app → Manage → Keys
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# Local only — run `pnpm dev:inngest` alongside `pnpm dev`
INNGEST_DEV=1
# Optional override if custom domain differs from VERCEL_URL
# INNGEST_SERVE_ORIGIN=https://getqalaunch.com

# ─── Browserbase (Playwright scans) ─────────────────────────────────────────
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# ─── Claude (AI analysis) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Google PageSpeed ─────────────────────────────────────────────────────────
GOOGLE_PAGESPEED_API_KEY=

# ─── Email / payments (paid flows) ───────────────────────────────────────────
RESEND_API_KEY=
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
