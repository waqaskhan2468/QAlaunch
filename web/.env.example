# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_OR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Claude
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override default model (must support prompt caching for best results)
ANTHROPIC_MODEL=claude-sonnet-4-6
# Optional: request hardening
ANTHROPIC_TIMEOUT_MS=90000
ANTHROPIC_MAX_RETRIES=2

# Google PageSpeed Insights
GOOGLE_PAGESPEED_API_KEY=YOUR_GOOGLE_API_KEY

# Resend
RESEND_API_KEY=re_...
FROM_EMAIL="QAlaunch <reports@yourdomain.com>"

# Inngest (background scan pipeline)
#
# Production (Vercel / hosted):
# 1. In https://app.inngest.com create an app and sync this codebase (or set the serve URL manually).
# 2. Set the app "Serve" / sync URL to: {NEXT_PUBLIC_APP_URL}/api/inngest
#    Example: https://your-domain.com/api/inngest — must match where Next is deployed.
# 3. Copy keys from the Inngest dashboard into Vercel (and local .env.local for prod-like tests):
INNGEST_EVENT_KEY=your_inngest_event_key
INNGEST_SIGNING_KEY=signkey-prod-...
# Production: omit INNGEST_DEV or set INNGEST_DEV=0 so the SDK uses Cloud mode (see lib/inngest/client.ts).
# INNGEST_DEV=0
#
# Local development:
# - Terminal A: pnpm dev   (Next must be on port 3000, or edit web/inngest.json + package.json dev:inngest URL)
# - Terminal B: pnpm dev:inngest   (syncs to Next /api/inngest; uses npx with install scripts enabled)
# - With `next dev`, NODE_ENV=development defaults to Inngest Dev mode in code. You can still set:
# INNGEST_DEV=1
# or a dev server URL, per https://www.inngest.com/docs/sdk/environment-variables#inngest-dev

# Browserbase (Playwright scan + PDF — runs inside Inngest on Next.js)
BROWSERBASE_API_KEY=bb_live_...
BROWSERBASE_PROJECT_ID=your_project_id
# Optional: session timeout in seconds (default 3600 for scans, 600 for PDF)
# BROWSERBASE_SESSION_TIMEOUT_SEC=3600
# Optional scanner / pipeline tuning
# SCAN_PAGE_TIMEOUT_MS=240000
# INNGEST_SCAN_CONCURRENCY=5
# POST /api/scan/start rate limits (per rolling hour)
# SCAN_START_RATE_LIMIT_PER_IP_HOUR=10
# SCAN_START_RATE_LIMIT_PER_EMAIL_HOUR=5
# SCAN_START_RATE_LIMIT_FREE_GLOBAL_HOUR=50
SUPABASE_SCREENSHOT_BUCKET=scan-screenshots
SUPABASE_REPORT_BUCKET=scan-reports
# Optional: signed download link lifetime in seconds (default 604800 = 7 days). Bucket can stay private.
# REPORT_SIGNED_URL_TTL_SECONDS=604800

# Paddle Billing (webhooks + browser checkout)
PADDLE_API_KEY=YOUR_PADDLE_API_KEY
PADDLE_WEBHOOK_SECRET=YOUR_PADDLE_WEBHOOK_SECRET
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=YOUR_PADDLE_CLIENT_TOKEN
# Optional: defaults to sandbox if unset (see checkout-experience.tsx)
# NEXT_PUBLIC_PADDLE_ENVIRONMENT=production
NEXT_PUBLIC_PADDLE_BASIC_PRICE_ID=pri_basic_xxx
NEXT_PUBLIC_PADDLE_STANDARD_PRICE_ID=pri_standard_xxx
NEXT_PUBLIC_PADDLE_PREMIUM_PRICE_ID=pri_premium_xxx
NEXT_PUBLIC_PADDLE_ENTERPRISE_PRICE_ID=pri_enterprise_xxx

# Local dev helpers (never enable in production)
# MOCK_CRAWLER=1
# MOCK_MAIL=1
# MOCK_PAGESPEED=1
# PAYMENT_TRUST_CLIENT=1
