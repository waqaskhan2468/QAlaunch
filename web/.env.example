# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_OR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Claude
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override default model (must support prompt caching for best results)
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
# Optional: request hardening
ANTHROPIC_TIMEOUT_MS=90000
ANTHROPIC_MAX_RETRIES=2

# Google PageSpeed Insights
GOOGLE_PAGESPEED_API_KEY=YOUR_GOOGLE_API_KEY

# Resend
RESEND_API_KEY=re_...
FROM_EMAIL="QAlaunch <reports@yourdomain.com>"

# QStash (Vercel / Upstash)
QSTASH_TOKEN=YOUR_QSTASH_TOKEN
QSTASH_CURRENT_SIGNING_KEY=YOUR_CURRENT_SIGNING_KEY
QSTASH_NEXT_SIGNING_KEY=YOUR_NEXT_SIGNING_KEY

# VPS crawl + PDF services (NOT on Vercel)
CRAWLER_SERVICE_URL=http://127.0.0.1:8080
CRAWLER_SERVICE_SECRET=long_random_shared_secret
PDF_SERVICE_URL=http://127.0.0.1:8080
PDF_SERVICE_SECRET=long_random_shared_secret_2
SCAN_SERVICE_URL=http://127.0.0.1:8080
SCAN_API_TOKEN=long_random_shared_secret
SUPABASE_REPORT_BUCKET=scan-reports
# Optional: signed download link lifetime in seconds (default 604800 = 7 days). Bucket can stay private.
# REPORT_SIGNED_URL_TTL_SECONDS=604800

# Paddle Billing (webhooks + browser checkout)
PADDLE_API_KEY=YOUR_PADDLE_API_KEY
PADDLE_WEBHOOK_SECRET=YOUR_PADDLE_WEBHOOK_SECRET
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=YOUR_PADDLE_CLIENT_TOKEN
# Optional: defaults to sandbox if unset (see checkout-experience.tsx)
# NEXT_PUBLIC_PADDLE_ENVIRONMENT=production
NEXT_PUBLIC_PADDLE_BASIC_PRICE_ID=pri_basic_xxx
NEXT_PUBLIC_PADDLE_STANDARD_PRICE_ID=pri_standard_xxx
NEXT_PUBLIC_PADDLE_PREMIUM_PRICE_ID=pri_premium_xxx
NEXT_PUBLIC_PADDLE_ENTERPRISE_PRICE_ID=pri_enterprise_xxx

# Local dev helpers (never enable in production)
# MOCK_CRAWLER=1
# MOCK_MAIL=1
# MOCK_PAGESPEED=1
# PAYMENT_TRUST_CLIENT=1
